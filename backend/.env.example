# Database
DATABASE_URL=postgresql://mockapi:mockapi@localhost:5432/mockapi

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
MOCK_BASE_URL=http://localhost:3000
APP_NAME=Mock API Studio

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=90

# Cache
MOCK_API_CACHE_TTL_SECONDS=60

# Rate limiting
GLOBAL_RATE_LIMIT_RPM=100
WORKSPACE_RATE_LIMIT_RPM=500

# Webhooks
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_MS=1000

# OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# SAML SSO (optional)
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

# AI providers (optional — Phase 25)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Pact Broker (optional — contract testing)
PACT_BROKER_BASE_URL=
PACT_BROKER_TOKEN=
PACT_BROKER_USERNAME=
PACT_BROKER_PASSWORD=

# Native gRPC wire server (optional)
GRPC_ENABLED=false
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
GRPC_PROTO_STORAGE_DIR=./data/grpc-protos
GRPC_MAX_RECEIVE_MESSAGE_LENGTH=4194304
GRPC_MAX_SEND_MESSAGE_LENGTH=4194304
GRPC_DEFAULT_WORKSPACE_ID=
GRPC_DEFAULT_API_SLUG=
