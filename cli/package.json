{
  "name": "@mock-api-studio/cli",
  "version": "1.0.0",
  "description": "Command-line interface for Mock API Studio",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mock-api": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mock",
    "api",
    "cli",
    "mock-server",
    "testing"
  ],
  "author": "Mock API Studio Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kscius/Mock-API-Studio.git"
  },
  "homepage": "https://github.com/kscius/Mock-API-Studio#readme",
  "bugs": {
    "url": "https://github.com/kscius/Mock-API-Studio/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "axios": "^1.6.2",
    "chalk": "^5.6.2",
    "ora": "^5.4.1",
    "conf": "^15.1.0",
    "cli-table3": "^0.6.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/inquirer": "^9.0.7",
    "typescript": "^7.0.2",
    "ts-node": "^10.9.2",
    "jest": "^30.4.2",
    "@types/jest": "^30.0.0",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

