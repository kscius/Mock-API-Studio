{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mock API Studio",
  "version": "1.0.0",
  "identifier": "dev.mockapistudio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../frontend",
    "beforeBuildCommand": "node ../../desktop/scripts/build-frontend.mjs",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Mock API Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:3000 http://localhost:3000 http://localhost:5173 ipc: http://ipc.localhost; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
